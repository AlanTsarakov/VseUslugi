@model Appeal


<div class="container mt-3" style="max-width: 500px;">
    <h3>Редактировать @Model.Id</h3>

    <form>
        <div class="mb-3">
            <label class="form-label small text-muted">ID</label>
            <input type="text" class="form-control" value="@Model.Id" disabled>
        </div>

        <div class="mb-3">
            <label class="form-label">Название</label>
            <input type="text" class="form-control" value="@Model.Name">
        </div>

        <div class="mb-3">
            <label class="form-label">Обращение</label>
            <input type="text" class="form-control" value="@Model.Description">
        </div>

        <a class="btn btn-outline-primary" asp-controller="Service" asp-action="Index">Сохранить</a>
        <a class="btn btn-outline-primary" asp-controller="Service" asp-action="Index">Отмена</a>
    </form>
</div>